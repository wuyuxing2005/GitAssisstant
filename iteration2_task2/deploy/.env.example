# Backend application settings. This file is copied to .env on the deploy host
# during the first deployment and is not overwritten afterwards.

AGENT_EVAL_DATABASE_URL=postgresql+psycopg://agent_eval:agent_eval@postgres:5432/agent_eval
AGENT_EVAL_RAGAS_DATASET_DIR=./data/eval_datasets
AGENT_EVAL_DATA_DIR=./data

# Leave the key empty to use heuristic judge fallbacks. Fill it on the server
# when real LLM-as-a-Judge evaluation is required.
