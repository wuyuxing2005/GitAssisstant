# 数据库配置
AGENT_EVAL_DATABASE_URL=postgresql+psycopg://agent_eval:agent_eval@postgres:5432/agent_eval

# Ragas 配置
AGENT_EVAL_RAGAS_DATASET_DIR=./data/eval_datasets

# LLM 配置
# OpenAI: AGENT_EVAL_RAGAS_LLM_MODEL=gpt-4o-mini, AGENT_EVAL_RAGAS_LLM_BASE_URL=https://api.openai.com/v1
# DeepSeek: AGENT_EVAL_RAGAS_LLM_MODEL=deepseek-chat, AGENT_EVAL_RAGAS_LLM_BASE_URL=https://api.deepseek.com/v1
AGENT_EVAL_RAGAS_LLM_MODEL=deepseek-chat
AGENT_EVAL_RAGAS_LLM_API_KEY=
AGENT_EVAL_RAGAS_LLM_BASE_URL=https://api.deepseek.com/v1

# Embedding 配置 (留空则复用 LLM 配置)
AGENT_EVAL_RAGAS_EMBEDDING_MODEL=
AGENT_EVAL_RAGAS_EMBEDDING_API_KEY=
AGENT_EVAL_RAGAS_EMBEDDING_BASE_URL=
